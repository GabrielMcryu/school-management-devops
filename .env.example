# Copy to .env and fill in real values. Do not commit .env.
SECRET_KEY=replace-with-your-own-secret-key
DEBUG=False
# In production include your VM's public IP and/or domain.
ALLOWED_HOSTS=localhost,127.0.0.1

# Where the app is served from (scheme required), for admin/browsable API CSRF.
# Comma-separated, e.g. http://<vm-ip> or http://school.example.com
CSRF_TRUSTED_ORIGINS=http://localhost

# Postgres
POSTGRES_DB=school
POSTGRES_USER=school
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
